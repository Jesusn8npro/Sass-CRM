OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
# Opcional — solo si activás voz por cuenta (responder con notas de voz):
ELEVENLABS_API_KEY=sk_...

# Opcional — URL pública del panel para webhooks de Vapi (transcripción
# + grabación). En dev local: ngrok / cloudflared.
# VAPI_PUBLIC_URL=https://tu-dominio.com

# ----- Vapi credenciales del SISTEMA (modelo SaaS) -----
# Por default, todas las cuentas de tus clientes usan ESTAS keys.
# Sus assistants se crean en TU cuenta de Vapi, las llamadas se cobran
# a TU billing. Si una cuenta puntual quiere usar otra cuenta de Vapi,
# puede pegar sus propias keys en /configuracion (override por cuenta).
#
# Conseguir en https://dashboard.vapi.ai → Settings → API Keys
VAPI_API_KEY=
# Public key — safe-to-expose, usada por @vapi-ai/web en el browser
# para test con micrófono.
VAPI_PUBLIC_KEY=
# Phone Number ID — el UUID del número comprado/importado en Vapi
# (NO es tu número celular).
VAPI_PHONE_NUMBER_ID=

# ----- Notificaciones de desconexión (opcional) -----
# Si está set, cuando una cuenta WhatsApp se desconecta el sistema
# manda email al usuario dueño avisando que tiene que reescanear QR.
# Sacar API key gratis (3K emails/mes) en https://resend.com
# RESEND_API_KEY=re_...
# Email "from" — debe ser un dominio verificado en Resend.
# RESEND_FROM=Sass-CRM <noreply@tu-dominio.com>

# Supabase (Auth + multi-tenant + DB + Storage)
# URL pública del proyecto (segura para exponer al cliente)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co

# ----- Claves NUEVAS (formato sb_*) -----
# Si tu proyecto tiene "Legacy API keys" deshabilitadas (default en
# proyectos creados después de mediados 2026), usá ESTE formato.

# Publishable (rol anon) — segura para exponer al browser, RLS protege.
# Dashboard → Settings → API Keys → Publishable keys.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Secret (rol service_role) — SOLO server-side. NUNCA con prefijo
# NEXT_PUBLIC_. Bypassea RLS, da acceso admin total.
# Dashboard → Settings → API Keys → Secret keys → "Reveal".
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
