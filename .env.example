OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
# Opcional — solo si activás voz por cuenta (responder con notas de voz):
ELEVENLABS_API_KEY=sk_...

# Opcional — URL pública del panel para webhooks de Vapi (Sprint 3 / llamadas).
# Necesario para que Vapi pueda mandarte transcripción + grabación al
# terminar cada llamada. En dev local podés usar ngrok / cloudflared.
# VAPI_PUBLIC_URL=https://tu-dominio.com

# La API key de Vapi NO va acá — se configura por cuenta desde el panel:
# Ajustes → Llamadas (Vapi) → "Vapi API Key". Cada negocio puede tener
# la suya.

# Para correr el bot dentro del proceso de Next (default) dejá esto sin
# tocar. Si por algún motivo querés que el bot corra como proceso
# separado, seteá BOT_EN_PROCESO=0 y arrancá manualmente con
# `npm run start:bot` en otra terminal.
# BOT_EN_PROCESO=0

# Supabase (Fase 6 — Auth + multi-tenant + DB en la nube)
# URL pública del proyecto (segura para exponer)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
# Clave publishable (anon) — segura para exponer al browser, RLS protege
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# Service role — SOLO server-side. NUNCA con prefijo NEXT_PUBLIC_.
# Bypassea RLS, da acceso admin total.
SUPABASE_SERVICE_ROLE_KEY=
